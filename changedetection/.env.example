# Copy to .env and adjust if needed:
#   cp .env.example .env

# Public URL shown in notification alerts (use your deployed URL in production)
BASE_URL=http://127.0.0.1:5000

# Host port mapping (default: localhost only)
CHANGEDETECTION_PORT=127.0.0.1:5000

# Scheduling timezone for watch checks
TZ=Europe/Madrid

# Allow watches on private/reserved IPs (LAN servers). Required for URLs like http://10.x.x.x/...
# Security: only enable on trusted networks; exposes SSRF if the UI is reachable by untrusted users.
ALLOW_IANA_RESTRICTED_ADDRESSES=false

# --- Storage / volume size ---
# Docker named volumes do NOT support a persistent size quota on Windows/macOS.
#
# Option A — bind mount (recommended): easier to inspect size on disk
# DATASTORE_VOLUME=./data
#
# Option B — ephemeral tmpfs with hard cap (data lost on `docker compose down -v`):
#   docker compose -f docker-compose.yml -f docker-compose.ephemeral.yml up -d
# DATASTORE_MAX_SIZE=512m
#
# Option C — reduce growth inside changedetection.io
SCREENSHOT_MAX_HEIGHT=8000
# Also set "History length" per watch in the UI (e.g. 5–10 snapshots)

# --- Config panel (URL → email) ---
CONFIG_PANEL_PORT=127.0.0.1:3000
# Static API key (auto-injected on startup; change in production)
CHANGEDETECTION_API_KEY=civio-monitor-dev
DEFAULT_CHECK_MINUTES=30
# --- SMTP (notificaciones por email) ---
# Ejemplo Gmail (app password): SMTP_HOST=smtp.gmail.com, PORT=587, SECURE=false
# Ejemplo SSL directo: PORT=465, SMTP_SECURE=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
NOTIFICATION_EMAIL_FROM=