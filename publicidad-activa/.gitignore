# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Bundler
/.bundle
/vendor/bundle

# Environment
/.env*

# Logs and temp files
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Storage and SQLite databases
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Credentials
/config/master.key

# Node
/node_modules
/yarn-error.log
npm-debug.log*

# Built assets (generated by esbuild and Tailwind)
/app/assets/builds/*
!/app/assets/builds/.keep

# Kamal secrets
/.kamal/secrets

# OS
.DS_Store
