<section class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
    <div>
      <span class="inline-flex items-center rounded-full border border-stone-200 bg-white px-3 py-1 text-xs text-stone-600 mb-4">
        Explorar por organismo
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-stone-900">
        Empieza por el ministerio u organismo
      </h2>
      <p class="mt-3 text-stone-600 max-w-xl leading-relaxed">
        Toda la información pública agrupada por la institución que la produce. Contratos, cargos, agenda y subvenciones de cada uno.
      </p>
    </div>
    <%= link_to "Ver todos los organismos →", organisms_path, class: "shrink-0 text-sm font-medium text-sky-700 hover:text-sky-800" %>
  </div>

  <div class="rounded-2xl border border-stone-200 bg-white overflow-hidden">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 divide-y sm:divide-x sm:divide-y divide-stone-200">
      <% featured_organisms.each do |organism| %>
        <%= link_to organism_path(organism[:code]), class: "group block p-6 sm:p-7 hover:bg-stone-50/80 transition-colors" do %>
          <div class="flex size-10 items-center justify-center rounded-lg border border-stone-200 bg-stone-50 text-stone-600 group-hover:border-sky-200 group-hover:bg-sky-50 group-hover:text-sky-700 transition-colors mb-4">
            <%= organism_icon(organism[:icon]) %>
          </div>
          <h3 class="font-semibold text-stone-900 group-hover:text-sky-800 transition-colors mb-1.5">
            <%= organism[:label] %>
          </h3>
          <p class="text-sm text-stone-600 leading-relaxed mb-4">
            <%= organism[:description] %>
          </p>
          <p class="text-[11px] font-medium uppercase tracking-wide text-stone-400">
            <%= organism_stats_label(organism[:count]) %>
          </p>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
