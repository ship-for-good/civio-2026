<div
  data-controller="chatbot"
  class="fixed bottom-5 right-5 z-[60] flex flex-col items-end gap-3"
>
  <div
    data-chatbot-target="panel"
    class="hidden w-80 sm:w-96 rounded-2xl border border-stone-200 bg-white shadow-xl shadow-stone-200/60 flex flex-col overflow-hidden"
    style="max-height: 560px;"
  >
    <div class="flex items-center justify-between gap-2 bg-sky-600 px-4 py-3">
      <div class="flex items-center gap-2 text-white">
        <svg class="size-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z"/>
        </svg>
        <span class="text-sm font-semibold">Asistente de transparencia</span>
      </div>
      <button
        type="button"
        data-action="click->chatbot#toggle"
        class="rounded-full p-1 text-white/80 hover:text-white hover:bg-sky-500 transition-colors"
        aria-label="Cerrar chat"
      >
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div
      data-chatbot-target="messages"
      class="flex-1 overflow-y-auto px-4 py-3 space-y-3 min-h-[160px]"
      aria-live="polite"
      aria-label="Conversación"
    >
      <div class="flex gap-2.5">
        <span class="mt-0.5 flex size-6 shrink-0 items-center justify-center rounded-full bg-sky-100 text-sky-700 text-xs font-bold">PA</span>
        <p class="rounded-2xl rounded-tl-none bg-stone-100 px-3 py-2 text-sm text-stone-800 leading-relaxed">
          Hola, soy el asistente de transparencia. Puedo ayudarte a encontrar información sobre contratos, subvenciones, cargos públicos y más. ¿En qué puedo ayudarte?
        </p>
      </div>
    </div>

    <div
      data-chatbot-target="loading"
      class="hidden px-4 py-2 flex items-center gap-2 text-xs text-stone-500"
      aria-label="El asistente está respondiendo"
    >
      <span class="flex size-6 shrink-0 items-center justify-center rounded-full bg-sky-100 text-sky-700 text-xs font-bold">PA</span>
      <span class="flex gap-1">
        <span class="size-1.5 rounded-full bg-stone-400 animate-bounce [animation-delay:0ms]"></span>
        <span class="size-1.5 rounded-full bg-stone-400 animate-bounce [animation-delay:150ms]"></span>
        <span class="size-1.5 rounded-full bg-stone-400 animate-bounce [animation-delay:300ms]"></span>
      </span>
    </div>

    <div
      data-chatbot-target="faqArea"
      class="hidden border-t border-stone-100 px-3 py-2 flex flex-wrap gap-1.5"
      aria-label="Preguntas frecuentes"
    >
    </div>

    <div class="border-t border-stone-200 px-3 py-2.5">
      <form
        data-action="submit->chatbot#submit"
        class="flex items-center gap-2"
        novalidate
      >
        <input
          type="text"
          name="question"
          data-chatbot-target="input"
          placeholder="Escribe tu pregunta…"
          autocomplete="off"
          required
          class="flex-1 min-w-0 rounded-full border border-stone-200 bg-stone-50 px-4 py-2 text-sm text-stone-900 placeholder:text-stone-400 focus:border-sky-300 focus:ring-2 focus:ring-sky-100 focus:outline-none transition-all"
        >
        <button
          type="submit"
          data-chatbot-target="sendButton"
          class="shrink-0 flex size-8 items-center justify-center rounded-full bg-sky-600 text-white hover:bg-sky-700 transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
          aria-label="Enviar pregunta"
        >
          <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5"/>
          </svg>
        </button>
      </form>
    </div>
  </div>

  <button
    type="button"
    data-action="click->chatbot#toggle"
    data-chatbot-target="toggleButton"
    class="flex size-12 items-center justify-center rounded-full bg-sky-600 text-white shadow-lg shadow-sky-600/30 hover:bg-sky-700 transition-colors focus:outline-none focus:ring-2 focus:ring-sky-400 focus:ring-offset-2"
    aria-label="Abrir asistente de transparencia"
    aria-expanded="false"
  >
    <svg data-chatbot-target="iconOpen" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round"
        d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z"/>
    </svg>
    <svg data-chatbot-target="iconClose" class="hidden size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
    </svg>
  </button>
</div>
