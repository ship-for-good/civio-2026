<%= form_with url: explore_path, method: :get do %>
  <% %i[organismo materia subtema tipo].each do |param| %>
    <% if params[param].present? %>
      <%= hidden_field_tag param, params[param] %>
    <% end %>
  <% end %>

  <div class="flex flex-col gap-5">
    <div class="flex items-center gap-3">
      <div class="flex flex-1 min-w-0 items-center rounded-full border border-stone-200 bg-white pl-5 pr-4 py-2.5 shadow-sm shadow-stone-200/50 focus-within:border-sky-300 focus-within:ring-2 focus-within:ring-sky-100 transition-all">
        <svg class="size-5 shrink-0 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/>
        </svg>
        <%= text_field_tag :q, params[:q],
          id: "q",
          placeholder: "Buscar por materia, organismo o palabra clave…",
          class: "flex-1 min-w-0 border-0 bg-transparent px-3 py-1 text-stone-900 placeholder:text-stone-400 focus:outline-none focus:ring-0 text-sm sm:text-base" %>
      </div>
      <%= submit_tag "Buscar →", class: "shrink-0 rounded-full bg-sky-600 px-5 sm:px-6 py-2.5 text-sm font-medium text-white hover:bg-sky-700 cursor-pointer transition-colors" %>
    </div>

    <div class="flex flex-wrap gap-2">
      <% ExploreHelper::VIGENCIA_OPTIONS.each do |option_label, value| %>
        <% active = explore_vigencia_value == value %>
        <%= link_to explore_path(explore_filter_params.merge("vigencia" => value)),
          class: explore_vigencia_pill_classes(active) do %>
          <%= option_label %>
          <span class="<%= explore_vigencia_count_classes(active) %>"><%= number_with_delimiter(@result.vigencia_counts[value]) %></span>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
