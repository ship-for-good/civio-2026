<%# locals: (resource:) %>
<li class="flex flex-col gap-5 rounded-2xl border border-stone-200 bg-white p-6 sm:flex-row sm:items-center sm:justify-between sm:gap-8 sm:p-7 shadow-sm shadow-stone-200/40">
  <div class="min-w-0 flex-1 space-y-4">
    <div class="space-y-2">
      <div class="flex flex-wrap items-start gap-3">
        <h2 class="min-w-0 flex-1 text-base sm:text-lg font-semibold text-stone-900 leading-snug">
          <%= resource.subtema_label %>
        </h2>
        <span class="<%= organism_stat_badge %> shrink-0">
          <%= explore_vigencia_label(resource.vigencia) %>
        </span>
      </div>
      <p class="text-sm text-stone-500 leading-relaxed">
        <%= resource.materia_label %>
      </p>
    </div>

    <div class="space-y-1.5 text-sm text-stone-600 leading-relaxed">
      <p>
        <%= link_to organism_path(resource.organismo_code),
          class: "font-medium text-sky-700 hover:text-sky-900 transition-colors" do %>
          <%= organism_label(resource.organismo_code) %>
        <% end %>
      </p>
      <% if resource.tipo.present? || resource.periodo.present? %>
        <p class="text-stone-500">
          <% metadata = [] %>
          <% metadata << resource.tipo.upcase if resource.tipo.present? %>
          <% metadata << resource.periodo if resource.periodo.present? %>
          <%= metadata.join(" · ") %>
        </p>
      <% end %>
    </div>
  </div>

  <div class="flex shrink-0 sm:items-end">
    <%= organism_external_link resource.url, label: "Visitar enlace", class: organism_btn_secondary("w-full sm:w-auto justify-center") %>
  </div>
</li>
