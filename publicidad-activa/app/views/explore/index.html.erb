<% content_for :title, "Explorar — Publicidad Activa" %>

<h1 class="text-2xl font-semibold mb-4">Explorar</h1>

<%= form_with url: explore_path, method: :get, class: "flex flex-wrap gap-2 mb-6" do |f| %>
  <%= f.text_field :q, value: params[:q], placeholder: "Buscar (ej. Defensa RPT)", class: "border border-gray-300 rounded px-3 py-2 flex-1 min-w-[200px]" %>
  <%= f.select :vigencia, [["Solo vigente", ""], ["Incluir histórico", "all"]], { selected: params[:vigencia] }, class: "border border-gray-300 rounded px-3 py-2" %>
  <%= f.submit "Buscar", class: "bg-blue-700 text-white px-4 py-2 rounded hover:bg-blue-800" %>
<% end %>

<p class="text-sm text-gray-600 mb-4"><%= @result.total %> resultados</p>

<ul class="space-y-3">
  <% @result.resources.first(50).each do |resource| %>
    <li class="bg-white border border-gray-200 rounded-lg p-4">
      <p class="font-medium"><%= resource.subtema_label %> · <%= resource.materia_label %></p>
      <% if resource.organismo_code.present? %>
        <p class="text-sm text-gray-600"><%= resource.organismo_code.upcase %> · <%= resource.tipo&.upcase %></p>
      <% end %>
      <p class="text-xs text-gray-500 mt-1"><%= resource.vigencia %><%= " · #{resource.periodo}" if resource.periodo.present? %></p>
      <%= link_to "Abrir en transparencia.gob.es", resource.url, target: "_blank", rel: "noopener", class: "text-sm text-blue-700 hover:underline mt-2 inline-block" %>
    </li>
  <% end %>
</ul>
