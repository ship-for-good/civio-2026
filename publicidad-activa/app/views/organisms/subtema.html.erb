<% content_for :main_class, OrganismsHelper::ORGANISM_MAIN_CLASS %>
<% content_for :title, "#{@subtema_label} — #{@label}" %>

<%= render "breadcrumb" %>

<%= render "page_header",
  title: @subtema_label,
  subtitle: "#{@label} · #{@materia_label}",
  badge: nil,
  icon: nil %>

<% if @vigente %>
  <section class="mb-6 sm:mb-8 rounded-2xl border border-stone-200 bg-white p-6 sm:p-8 shadow-sm">
    <h2 class="text-sm font-semibold uppercase tracking-wide text-stone-500 mb-4">Versión vigente</h2>
    <%= organism_external_link @vigente.url, class: organism_btn_primary %>
  </section>
<% end %>

<% if @historicos.any? %>
  <section class="rounded-2xl border border-stone-200 bg-stone-50/60 p-6 sm:p-8 shadow-sm">
    <header class="mb-6">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <h2 class="text-xl font-bold text-stone-900">Histórico</h2>
        <span class="<%= organism_stat_badge %>">
          <%= organism_resource_count(@historicos.size) %>
        </span>
      </div>
    </header>

    <ul class="space-y-3">
      <% @historicos.each do |resource| %>
        <li class="flex flex-col gap-4 rounded-2xl border border-stone-200 bg-white p-5 sm:flex-row sm:items-center sm:justify-between sm:p-6 shadow-sm">
          <div class="min-w-0">
            <p class="font-semibold text-stone-900">
              <%= resource.periodo.presence || "Sin periodo" %>
            </p>
            <% if resource.tipo %>
              <p class="mt-1 text-sm text-stone-500"><%= resource.tipo.upcase %></p>
            <% end %>
          </div>
          <%= organism_external_link resource.url, label: "Abrir", class: organism_btn_secondary %>
        </li>
      <% end %>
    </ul>
  </section>
<% end %>

<%= render "page_footer", back_path: organism_materia_path(@code, @materia, **organism_nav_scope_params), back_label: @materia_label %>
