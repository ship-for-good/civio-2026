<nav aria-label="Breadcrumb" class="mb-6 sm:mb-8 -mx-4 px-4 sm:mx-0 sm:px-0 overflow-x-auto">
  <ol class="flex items-center gap-2 text-sm text-stone-500 whitespace-nowrap min-w-0">
    <li class="shrink-0">
      <%= link_to organisms_index_label, organisms_index_path, class: "hover:text-sky-700 transition-colors" %>
    </li>

    <% if @code %>
      <li class="shrink-0 text-stone-300" aria-hidden="true"><%= organism_breadcrumb_chevron %></li>
      <li class="min-w-0 max-w-[10rem] sm:max-w-xs truncate">
        <% if @materia %>
          <%= link_to @label, organism_path(@code, **organism_nav_scope_params), class: "hover:text-sky-700 transition-colors block truncate" %>
        <% else %>
          <span class="font-medium text-stone-900 truncate block"><%= @label %></span>
        <% end %>
      </li>
    <% end %>

    <% if @materia %>
      <li class="shrink-0 text-stone-300" aria-hidden="true"><%= organism_breadcrumb_chevron %></li>
      <li class="min-w-0 max-w-[10rem] sm:max-w-xs truncate">
        <% if @subtema %>
          <%= link_to @materia_label, organism_materia_path(@code, @materia, **organism_nav_scope_params), class: "hover:text-sky-700 transition-colors block truncate" %>
        <% else %>
          <span class="font-medium text-stone-900 truncate block"><%= @materia_label %></span>
        <% end %>
      </li>
    <% end %>

    <% if @subtema %>
      <li class="shrink-0 text-stone-300" aria-hidden="true"><%= organism_breadcrumb_chevron %></li>
      <li class="min-w-0 max-w-[10rem] sm:max-w-md truncate">
        <span class="font-medium text-stone-900 truncate block"><%= @subtema_label %></span>
      </li>
    <% end %>
  </ol>
</nav>
