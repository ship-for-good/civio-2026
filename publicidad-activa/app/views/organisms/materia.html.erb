<% content_for :main_class, OrganismsHelper::ORGANISM_MAIN_CLASS %>
<% content_for :title, "#{@materia_label} — #{@label}" %>

<%= render "breadcrumb" %>

<%= render "page_header",
  title: @materia_label,
  subtitle: @label,
  badge: nil,
  icon: nil %>

<%= render "materia_tabs" %>

<section class="mt-2">
  <header class="mb-6 sm:mb-8">
    <h2 class="text-xl sm:text-2xl font-bold tracking-tight text-stone-900">
      Apartados de esta materia
    </h2>
    <p class="mt-2 text-sm sm:text-base text-stone-500 leading-relaxed">
      Información publicada de forma proactiva.
    </p>
  </header>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-5">
    <% @subtemas.each do |subtema| %>
      <%= render "subtema_card", subtema: subtema %>
    <% end %>
  </div>
</section>

<%= render "page_footer", back_path: organism_path(@code, **organism_nav_scope_params), back_label: @label %>
