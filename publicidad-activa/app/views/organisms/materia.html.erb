<% content_for :title, "#{@materia_label} — #{@label}" %>

<%= render "breadcrumb" %>

<h1 class="text-2xl font-semibold mb-1"><%= @materia_label %></h1>
<p class="text-sm text-gray-500 mb-6"><%= @label %></p>

<ul class="space-y-3">
  <% @subtemas.each do |subtema| %>
    <li class="bg-white border border-gray-200 rounded-lg p-4">
      <p class="font-medium"><%= subtema.label %></p>
      <p class="text-sm text-gray-500 mt-1"><%= subtema.count %> recursos</p>

      <div class="mt-3 flex flex-wrap gap-x-4 gap-y-2">
        <% if subtema.vigente_url.present? %>
          <%= link_to "Abrir en transparencia.gob.es", subtema.vigente_url, target: "_blank", rel: "noopener", class: "text-sm text-blue-700 hover:underline" %>
        <% elsif subtema.has_historico %>
          <%= link_to "Ver recursos", organism_subtema_path(@code, @materia, subtema.slug), class: "text-sm text-blue-700 hover:underline" %>
        <% end %>

        <% if subtema.has_historico %>
          <%= link_to "Ver versiones históricas", organism_subtema_path(@code, @materia, subtema.slug), class: "text-sm text-gray-600 hover:text-blue-700 hover:underline" %>
        <% end %>
      </div>
    </li>
  <% end %>
</ul>

<p class="mt-6"><%= link_to "← #{@label}", organism_path(@code), class: "text-blue-700 hover:underline" %></p>
