<%# locals: (title:, count: nil, description: nil) %>
<div class="mb-5 sm:mb-6">
  <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
    <h2 class="text-lg sm:text-xl font-semibold text-stone-900"><%= title %></h2>
    <% if local_assigns[:count] %>
      <span class="text-sm text-stone-500 tabular-nums"><%= count %></span>
    <% end %>
  </div>
  <% if local_assigns[:description] %>
    <p class="mt-2 text-sm sm:text-base text-stone-600 leading-relaxed max-w-3xl"><%= description %></p>
  <% end %>
</div>
