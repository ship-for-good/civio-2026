<% content_for :title, "#{@label} — Organismos" %>

<%= render "breadcrumb" %>

<h1 class="text-2xl font-semibold mb-1"><%= @label %></h1>
<% if @codes.size > 1 %>
  <p class="text-sm text-gray-500 mb-6"><%= @codes.map(&:upcase).join(" · ") %></p>
<% else %>
  <p class="text-sm text-gray-500 mb-6"><%= @code.upcase %></p>
<% end %>

<% if @materias.any? %>
  <ul class="space-y-3">
    <% @materias.each do |materia| %>
      <li class="bg-white border border-gray-200 rounded-lg p-4">
        <%= link_to organism_materia_path(@code, materia.slug), class: "block group" do %>
          <p class="font-medium text-blue-700 group-hover:underline"><%= materia.label %></p>
          <p class="text-sm text-gray-500 mt-1"><%= materia.count %> recursos</p>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <div class="bg-white border border-gray-200 rounded-lg p-6">
    <p class="text-gray-600">No hay recursos indexados para este organismo.</p>
    <p class="mt-3">
      <%= link_to "Explorar recursos", explore_path(organismo: @code), class: "text-blue-700 hover:underline" %>
    </p>
  </div>
<% end %>

<p class="mt-6"><%= link_to "← Organismos", organisms_path, class: "text-blue-700 hover:underline" %></p>
