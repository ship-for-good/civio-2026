<% content_for :main_class, OrganismsHelper::ORGANISM_MAIN_CLASS %>
<% content_for :title, "#{@label} — Organismos" %>

<%= render "entity_header",
  title: @label,
  subtitle: @catalog_entry&.description,
  badge: organism_code_badge(@codes, @code),
  icon: @catalog_entry&.icon %>

<% if @materias.any? %>
  <section>
    <header class="mb-6 sm:mb-8">
      <h2 class="text-xl sm:text-2xl font-bold tracking-tight text-stone-900">
        ¿Qué información existe?
      </h2>
      <p class="mt-2 text-sm sm:text-base text-stone-500 leading-relaxed max-w-3xl">
        Materias de publicidad activa publicadas por este organismo.
      </p>
    </header>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-5">
      <% @materias.each do |materia| %>
        <%= link_to organism_materia_path(@code, materia.slug, **organism_nav_scope_params), class: organism_card_link_classes do %>
          <div class="flex items-start justify-between gap-3">
            <h3 class="min-w-0 flex-1 text-base font-semibold text-stone-900 leading-snug group-hover:text-sky-800 transition-colors">
              <%= materia.label %>
            </h3>
            <span class="flex size-8 shrink-0 items-center justify-center rounded-full text-stone-400 group-hover:bg-stone-50 group-hover:text-stone-600 transition-colors">
              <%= organism_breadcrumb_chevron %>
            </span>
          </div>

          <p class="mt-2 text-sm text-stone-500 leading-relaxed">
            Subtemas y recursos indexados en esta materia.
          </p>

          <div class="mt-5 pt-5 border-t border-stone-100">
            <p class="text-sm text-stone-500">
              <span class="text-xl font-bold tabular-nums text-stone-900"><%= number_with_delimiter(materia.count) %></span>
              <%= materia.count == 1 ? "recurso" : "recursos" %>
            </p>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>
<% else %>
  <section class="rounded-2xl border border-stone-200 bg-white px-6 py-12 sm:px-10 sm:py-16 text-center shadow-sm">
    <div class="mx-auto flex size-14 items-center justify-center rounded-2xl bg-stone-100 text-stone-500 mb-6">
      <svg class="size-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
      </svg>
    </div>
    <p class="text-lg font-semibold text-stone-900">No hay recursos indexados para este organismo</p>
    <p class="mt-3 text-sm sm:text-base text-stone-500 max-w-md mx-auto leading-relaxed">
      Puedes buscar en el explorador general por si hay datos relacionados.
    </p>
    <div class="mt-8">
      <%= link_to "Explorar recursos", explore_path(organismo: @code), class: organism_btn_primary("sm:px-8") %>
    </div>
  </section>
<% end %>
