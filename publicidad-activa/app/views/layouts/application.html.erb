<!DOCTYPE html>
<html lang="es">
  <head>
    <title><%= content_for(:title) || "Publicidad Activa" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <header class="bg-white border-b border-gray-200">
      <div class="max-w-5xl mx-auto px-4 py-4 flex flex-wrap items-center justify-between gap-4">
        <a href="<%= root_path %>" class="font-semibold text-lg">Publicidad Activa</a>
        <nav class="flex flex-wrap gap-4 text-sm">
          <%= link_to "Inicio", root_path, class: "hover:text-blue-700" %>
          <%= link_to "Explorar", explore_path, class: "hover:text-blue-700" %>
          <%= link_to "Organismos", organisms_path, class: "hover:text-blue-700" %>
          <%= link_to "Mapa URLs", url_map_path, class: "hover:text-blue-700" %>
        </nav>
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-4 py-8">
      <%= yield %>
    </main>
  </body>
</html>
