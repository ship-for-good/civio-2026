# Copia este fichero a .env y rellena los valores. NUNCA commitees .env.

# --- Phoenix ---
SECRET_KEY_BASE=
PHX_HOST=localhost
PORT=4000

# --- Database (Postgres) ---
DATABASE_URL=ecto://postgres:postgres@localhost/sqlete_dev

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_EMBEDDER_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-5.4-mini

# --- Alertas de plazo (Twilio: SMS / llamada) ---
# Proveedor: "twilio" envía de verdad; vacío o "fake" = no envía (solo registra/loguea).
ALERTS_PROVIDER=
# Canal: sms | call | both. SMS es lo más fiable (y funciona en cuentas trial).
ALERTS_CHANNEL=
# Días restantes que disparan el aviso automático (cron diario). Por defecto 5.
ALERTS_THRESHOLD_DAYS=
# Número destino en formato E.164, p. ej. +34685888716
ALERT_TO_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- AWS / deploy (configurar como GitHub Actions secrets, no aquí) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
EC2_HOST=
EC2_SSH_PRIVATE_KEY=
